#!/bin/sh
# OpenRelix pre-commit hook — block commits that leak personal info.
#
# Install once per clone:
#   ln -s ../../scripts/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# The hook runs scripts/check_personal_info.py. The check uses built-in
# regexes (user-home paths, hardcoded credentials, personal-email tails) plus
# any patterns at <state_root>/personal_denylist.txt. Set
# OPENRELIX_SKIP_PERSONAL_CHECK=1 in the environment to bypass for one commit
# (use sparingly — the check exists to keep private project names out of git).

set -e

if [ "${OPENRELIX_SKIP_PERSONAL_CHECK:-0}" = "1" ]; then
    echo "personal-info-check: skipped via OPENRELIX_SKIP_PERSONAL_CHECK=1"
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
exec python3 "$ROOT/scripts/check_personal_info.py"
